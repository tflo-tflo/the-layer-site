---
const properties = [
  { value: 'atami-hotel', label: 'The Layer | Atami Hotel' },
  { value: 'atami-garden', label: 'The Layer | Atami Garden' },
  { value: 'ito', label: 'The Layer | Ito' },
  { value: 'tangram', label: 'The Layer | Tangram (Nagano)' },
  { value: 'shimoda', label: 'The Layer | Shimoda' },
];
---

<section class="booking" aria-label="Book a stay">
  <form class="booking__form" action="#" method="get" novalidate>
    <div class="booking__field">
      <label for="property">Property</label>
      <select id="property" name="property" required>
        <option value="">Select a property</option>
        {properties.map(p => (
          <option value={p.value}>{p.label}</option>
        ))}
      </select>
    </div>

    <div class="booking__field">
      <label for="checkin">Check-in</label>
      <input type="date" id="checkin" name="checkin" required />
    </div>

    <div class="booking__field">
      <label for="checkout">Check-out</label>
      <input type="date" id="checkout" name="checkout" required />
    </div>

    <div class="booking__field booking__field--guests">
      <label for="guests">Guests</label>
      <select id="guests" name="guests">
        {[1,2,3,4,5,6,7,8].map(n => (
          <option value={n}>{n} {n === 1 ? 'guest' : 'guests'}</option>
        ))}
      </select>
    </div>

    <div class="booking__field">
      <label for="code">Promo code</label>
      <input type="text" id="code" name="code" placeholder="Optional" autocomplete="off" />
    </div>

    <button type="submit" class="booking__submit">Book Now</button>
  </form>
</section>

<style>
  .booking {
    padding-block: 2rem;
  }

  .booking__form {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr 1fr auto;
    gap: 0;
    border: 1.5px solid #000;
  }

  .booking__field {
    display: flex;
    flex-direction: column;
    padding: 0.75rem 1rem;
    border-right: 1px solid #ccc;
  }

  .booking__field:last-of-type {
    border-right: none;
  }

  .booking__field label {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.25rem;
    opacity: 0.6;
  }

  .booking__field select,
  .booking__field input {
    font-family: var(--font-body);
    font-size: 0.95rem;
    border: none;
    outline: none;
    background: transparent;
    cursor: pointer;
    width: 100%;
  }

  .booking__submit {
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 600;
    padding: 0 2rem;
    background: #000;
    color: #fff;
    border: none;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.2s;
  }
  .booking__submit:hover { background: #333; }

  @media (max-width: 900px) {
    .booking__form {
      grid-template-columns: 1fr 1fr;
    }

    .booking__field {
      border-right: none;
      border-bottom: 1px solid #ccc;
    }

    .booking__submit {
      grid-column: 1 / -1;
      padding: 1rem;
    }
  }

  @media (max-width: 480px) {
    .booking__form { grid-template-columns: 1fr; }
  }
</style>
